{
	"_version": "1.81.0",
	"sap.app": {
		"id": "managepos",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.20.2",
			"toolsId": "223485a7-72a5-45a8-b83b-25412bbf4c54"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/procurement/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		},
		"crossNavigation": {
			"inbounds": {
				"purchaseOrders-manage": {
					"semanticObject": "purchaseOrders",
					"action": "manage",
					"signature": {
						"parameters": {},
						"additionalParameters": "allowed"
					}
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.145.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {},
				"sap.f": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "managepos.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "POList",
					"target": [
						"POList"
					]
				},
				{
					"pattern": "PO({key}):?query:",
					"name": "POObjectPage",
					"target": [
						"POList",
						"POObjectPage"
					]
				},
				{
					"pattern": "PO({key})/poItems({key2}):?query:",
					"name": "POItemsObjectPage",
					"target": [
						"POList",
						"POObjectPage",
						"POItemsObjectPage"
					]
				}
			],
			"targets": {
				"POList": {
					"type": "Component",
					"id": "POList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/PO",
							"variantManagement": "Page",
							"navigation": {
								"PO": {
									"detail": {
										"route": "POObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "ResponsiveTable"
									}
								}
							},
							"initialLoad": "Enabled"
						}
					}
				},
				"POObjectPage": {
					"type": "Component",
					"id": "POObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/PO",
							"navigation": {
								"poItems": {
									"detail": {
										"route": "POItemsObjectPage"
									}
								}
							}
						}
					}
				},
				"POItemsObjectPage": {
					"type": "Component",
					"id": "POItemsObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/PO/poItems"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "transactional"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	},
	"sap.cloud": {
		"public": true,
		"service": "retail_inventory_and_billing_mgmt_system_v2.service"
	}
}